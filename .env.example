# AI Personal Assistants - Local Environment Secrets Template
# Copy this file to '.env' and fill in your keys.

# Hugging Face Access Token (Required for Qwen 2.5 models)
HF_TOKEN="your_huggingface_access_token_here"

# Anthropic API Key (Required for Claude Sonnet & evaluations)
ANTHROPIC_API_KEY="your_anthropic_api_key_here"

# Google Gemini API Key (Required for free-tier Gemini and LLM-as-judge evaluations)
GEMINI_API_KEY="your_gemini_api_key_here"

